# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Database Configuration
MONGODB_URI=mongodb://admin:password@mongodb:27017/milagro?authSource=admin
DB_URI=mongodb://admin:password@mongodb:27017/milagro?authSource=admin
DB_HOST=mongodb
DB_PORT=27017

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# API Configuration
API_BASE_URL=http://ecommerce-api:3000/api
PORT=3000
CORS_URL=http://localhost:3001

# MCP Server Configuration
MCP_SERVER_COMMAND=node
MCP_SERVER_ARGS=../mcp-server/dist/server.js
MCP_PORT=3002
MCP_API_KEY=your-secure-mcp-api-key-here

# Python Agent Configuration
AGENT_NAME=ecommerce-assistant
AGENT_VERSION=1.0.0

# Redis Configuration (optional)
REDIS_URL=redis://redis:6379

# Application Configuration
NODE_ENV=development
BASE_URL=http://localhost:3000
APP_NAME=Milagro
APP_VERSION=1.0.0
